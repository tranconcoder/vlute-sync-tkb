{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run start script",
      "type": "shell",
      "command": "./scripts/start.sh",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true,
        "focus": true
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^([^\\s].*)\\((\\d+|\\d+,\\d+|\\d+,\\d+,\\d+,\\d+)\\):\\s+(error|warning|info)\\s+(TS\\d+)\\s*:\\s*(.*)$",
          "file": 1,
          "location": 2,
          "severity": 3,
          "code": 4,
          "message": 5
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^Using environment file:",
          "endsPattern": "Nest application successfully started"
        }
      }
    }
  ]
}
